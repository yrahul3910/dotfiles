{
  // Redesigned bash permission format (pi-permission-system 0.8.0-patch.2).
  // Rules are word-prefix lists matched per executed command; read-only
  // commands (rg, grep, cat, git log, ...) are allowed by the built-in
  // safe-command registry, and .env/.ssh/key files are denied by built-in
  // protected paths — no per-command deny globs needed anymore.
  "bash": {
    "allow": [
      "cargo clippy",
      "cargo check",
      "cargo fmt",
      "bun test",
      "gh run view",
    ],
    "ask": ["cargo test", "uv run pytest"],
  },
  "defaultPolicy": {
    "tools": "ask",
    "bash": "ask",
    "mcp": "ask",
    "skills": "ask",
    "special": "ask",
  },
  "tools": {
    "read": "allow",
    "grep": "allow",
    "find": "allow",
    "ls": "allow",
    "write": "ask",
    "edit": "ask",
    "mcp_kagi_kagi_search_fetch": "allow",
    "mcp_kagi_kagi_extract": "allow",
  },
}
