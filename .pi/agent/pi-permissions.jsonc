{
  "bash": {
    "rm *": "ask",
    "rg *": "allow",
    "grep *": "allow",
    "fd *": "allow",
    "ls *": "allow",
    "cat *": "allow",
    "cat *.env": "deny",  // last match wins
    "sed *": "allow",
    "echo *": "allow",
    "head *": "allow",
    "tail *": "allow",
    "python *": "ask",
    "python3 *": "ask",
    "uv run python3 *": "ask",
    "uv run python *": "ask",
    "cargo clippy *": "allow",
    "cargo check *": "allow",
    "cargo test *": "allow",
    "bun test": "allow",
    "uv run pytest *": "allow",
    "git diff *": "allow",
    "git status *": "allow",
  },
  "defaultPolicy": {
    "tools": "ask",
    "bash": "ask",
    "mcp": "ask",
    "skills": "ask",
    "special": "ask"
  },
  "tools": {
    "read": "allow",
    "grep": "allow",
    "find": "allow",
    "ls": "allow",
    "write": "ask",
    "edit": "ask"
  }
}
